{
  "name": "demo-worker",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "wrangler build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
