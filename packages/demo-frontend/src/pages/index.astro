---
import AppLayout from '../layouts/AppLayout.astro'
import SectionHeader from '../components/astro/SectionHeader.astro'
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '../components/ui/card'
import { Badge } from '../components/ui/badge'
---

<AppLayout title="Project Overview">
  <div class="space-y-10">
    <section class="rounded-[28px] border border-slate-200 bg-white/80 p-8 shadow-sm dark:border-slate-700 dark:bg-slate-900/70">
      <SectionHeader
        title="Project introduction"
        description="Forum demo with posts, authentication, and a clean multi-page layout."
      />
      <div class="mt-4 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white/70 p-4 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-300">
          <Badge>Posts</Badge>
          <div class="mt-2">Create, edit, and open individual posts.</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white/70 p-4 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-300">
          <Badge>Auth</Badge>
          <div class="mt-2">Sign up, sign in, and manage your session.</div>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white/70 p-4 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-900/60 dark:text-slate-300">
          <Badge>Multi-page</Badge>
          <div class="mt-2">Dedicated routes for forum, account, and posts.</div>
        </div>
      </div>
      <div class="mt-6">
        <a
          class="rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white dark:bg-slate-100 dark:text-slate-900"
          href="/forum"
        >
          View the forum
        </a>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
      <Card className="dark:border-slate-700 dark:bg-slate-900/70">
        <CardHeader>
          <CardTitle>Frontend</CardTitle>
          <CardDescription>UI framework mix and component libraries.</CardDescription>
        </CardHeader>
        <CardContent className="space-y-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">
              Frameworks
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
              <a class="inline-flex" href="https://astro.build" target="_blank" rel="noreferrer">
                <Badge>Astro</Badge>
              </a>
              <a class="inline-flex" href="https://react.dev" target="_blank" rel="noreferrer">
                <Badge>React</Badge>
              </a>
              <a class="inline-flex" href="https://vuejs.org" target="_blank" rel="noreferrer">
                <Badge>Vue</Badge>
              </a>
            </div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Astro handles routing and layouts, while React and Vue power interactive islands.
            </p>
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">
              Libraries
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
              <a class="inline-flex" href="https://reui.io" target="_blank" rel="noreferrer">
                <Badge>ReUI</Badge>
              </a>
              <a class="inline-flex" href="https://ui.shadcn.com" target="_blank" rel="noreferrer">
                <Badge>shadcn/ui</Badge>
              </a>
              <a class="inline-flex" href="https://tailwindcss.com" target="_blank" rel="noreferrer">
                <Badge>Tailwind</Badge>
              </a>
            </div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              ReUI and shadcn/ui provide the component base, styled with Tailwind utilities.
            </p>
          </div>
        </CardContent>
      </Card>

      <Card className="dark:border-slate-700 dark:bg-slate-900/70">
        <CardHeader>
          <CardTitle>Backend</CardTitle>
          <CardDescription>APIs, auth, and infrastructure.</CardDescription>
        </CardHeader>
        <CardContent className="space-y-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">
              Libraries
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
              <a class="inline-flex" href="https://www.better-auth.com" target="_blank" rel="noreferrer">
                <Badge>better-auth</Badge>
              </a>
              <a class="inline-flex" href="https://trpc.io" target="_blank" rel="noreferrer">
                <Badge>tRPC</Badge>
              </a>
            </div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              better-auth manages sessions while tRPC powers typed API calls.
            </p>
          </div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">
              Technology
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
              <a class="inline-flex" href="https://developers.cloudflare.com/workers/" target="_blank" rel="noreferrer">
                <Badge>Cloudflare Workers</Badge>
              </a>
              <a class="inline-flex" href="https://developers.cloudflare.com/d1/" target="_blank" rel="noreferrer">
                <Badge>D1</Badge>
              </a>
            </div>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Workers host the API, with D1 storing forum data.
            </p>
          </div>
        </CardContent>
      </Card>
    </section>
  </div>
</AppLayout>
