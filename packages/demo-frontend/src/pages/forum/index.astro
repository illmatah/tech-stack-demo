---
import AppLayout from '../../layouts/AppLayout.astro'
import ForumBoard from '../../components/react/forum/ForumBoard'
import SectionHeader from '../../components/astro/SectionHeader.astro'
import IdeaBoard from '../../components/vue/IdeaBoard.vue'
---

<AppLayout title="Forum Board">
  <section class="space-y-6">
    <SectionHeader
      title="Forum"
      description="Browse posts and open the ones you care about."
    />
    <div class="grid gap-6 lg:grid-cols-[2fr,1fr]">
      <ForumBoard client:visible />
      <IdeaBoard client:visible />
    </div>
  </section>
</AppLayout>
