---
import AppLayout from '../../layouts/AppLayout.astro'
import SectionHeader from '../../components/astro/SectionHeader.astro'
import { PostDetail } from '../../components/react/forum/PostDetail'


export const prerender = false

const { id } = Astro.params
---

<AppLayout title="Forum Post">
  <section class="space-y-6">
    <SectionHeader
      title="Forum post"
      description="The full post, ready to read or edit if it is yours."
    />
    {id ? <PostDetail postId={id} client:visible /> : null}
  </section>
</AppLayout>
