---
import '../styles/global.css'
import ThemeToggle from '../components/astro/ThemeToggle.astro'
import { HeaderNav } from '../components/react/HeaderNav'


type Props = {
  title?: string
}

const { title = 'Stacked Forum Demo' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const storageKey = 'theme'
        const stored = localStorage.getItem(storageKey)
        const theme = stored === 'light' || stored === 'dark'
          ? stored
          : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
        document.documentElement.classList.toggle('dark', theme === 'dark')
      })()
    </script>
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_top,_#eef2ff,_#ffffff_55%)] text-slate-900 dark:bg-[radial-gradient(circle_at_top,_#0f172a,_#020617_60%)] dark:text-slate-100">
    <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col gap-8 px-6 py-10">
      <header class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">
            Astro Stack Demo
          </div>
          <div class="text-2xl font-semibold">Forum Studio</div>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <ThemeToggle />
          <HeaderNav client:load />
        </div>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class="text-xs text-slate-500">
        Built with Astro + React + Vue components.
      </footer>
    </div>
  </body>
</html>
