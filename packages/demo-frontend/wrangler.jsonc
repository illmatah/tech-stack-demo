{
	"main": "dist/_worker.js/index.js",
	"name": "demo-frontend",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
  "vars": {
    "API_URL": "https://ai-edu-demo-stack.illmatah.workers.dev"
  }
}